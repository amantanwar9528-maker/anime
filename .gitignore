# secrets never go to GitHub (they live in GitHub Secrets instead)
config.yaml
secrets/
.env
*.log

# transient working output
data/output/
data/logs/

# KEEP state (run history, music index, used stories) so cloud runs remember
!data/state/
!data/state/.gitkeep
!data/state/state.json

# KEEP your music in the repo so the cloud runner can use it
!assets/music/
!assets/music/*.mp3
!assets/music/*.m4a
!assets/music/*.wav

# downloaded fonts (re-created at runtime)
assets/fonts/*.ttf

# python
__pycache__/
*.pyc
